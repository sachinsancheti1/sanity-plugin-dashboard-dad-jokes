{
  "name": "sanity-plugin-dashboard-dad-jokes",
  "version": "2.0.0",
  "description": "A dashboard widget for Sanity Content Studio to obtain dad jokes",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "dashboard",
    "widget",
    "dad-jokes"
  ],
  "homepage": "https://github.com/sachinsancheti1/sanity-plugin-dashboard-dad-jokes#readme",
  "bugs": {
    "url": "https://github.com/sachinsancheti1/sanity-plugin-dashboard-dad-jokes/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sachinsancheti1/sanity-plugin-dashboard-dad-jokes.git"
  },
  "license": "MIT",
  "author": "Sachin Sancheti <sachin.sancheti@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "browserslist": "extends @sanity/browserslist-config",
  "sideEffects": false,
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "clean": "rimraf dist",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@sanity/ui": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/pkg-utils": "^7.9.7",
    "@sanity/plugin-kit": "^4.0.19",
    "@types/react": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.18",
    "react": "^19",
    "react-dom": "^19.1.0",
    "react-is": "^19.1.0",
    "rimraf": "^6.0.1",
    "sanity": "^4",
    "styled-components": "^6.1.19",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@sanity/dashboard": "^5",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "sanity": "^3 || ^4 || ^5"
  },
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "eslintImports": false,
      "sanityV2Json": false
    }
  }
}
